# Copy to .env and fill in real values. Both server.py and workflow.py
# load this file (each via load_dotenv()), so a single .env covers both.

# OpenAI — used by the LangChain agent in workflow.py.
OPENAI_API_KEY=sk-...

# Arcade — the local MCP server uses Arcade as the OAuth authorization server
# (token validation against cloud.arcade.dev/oauth2) AND as the Google OAuth
# broker for the @tool(requires_auth=Google(...)) tools. The agent (workflow.py)
# does NOT call Arcade directly — only the server does.
ARCADE_API_KEY=arc_...

# Your email address — Arcade scopes Google OAuth tokens per ARCADE_USER_ID, and
# the default user_query in workflow.py templates this in as the email recipient.
ARCADE_USER_ID=you@example.com

# Galileo — destination for the stitched client+server trace.
GALILEO_API_KEY=...
GALILEO_PROJECT=arcade-galileo-demo
GALILEO_LOG_STREAM=default

# Optional — Galileo console URL for non-default clusters (dev / staging /
# demo-v2 / self-hosted). Default is https://app.galileo.ai/. If you set this,
# GALILEO_API_KEY must be a key issued on that cluster. Both the
# GalileoSpanProcessor and the manual passback ingest derive the OTLP
# endpoint from this — no manual GALILEO_OTLP_ENDPOINT needed.
# GALILEO_CONSOLE_URL=https://console.demo-v2.galileocloud.io/

# Optional — explicit override for the OTLP traces endpoint used by the
# manual passback POST. Almost never needed; only set this if your cluster's
# OTLP path differs from the standard `<console>/api/galileo/otel/traces`.
# GALILEO_OTLP_ENDPOINT=https://app.galileo.ai/api/galileo/otel/traces
