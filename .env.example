# Copy to .env and fill in real values.

OPENAI_API_KEY=sk-...
ARCADE_API_KEY=arc_...
GALILEO_API_KEY=...

# Optional — override the Galileo console URL to target a non-default cluster
# (e.g. demov2: https://console.demo-v2.galileocloud.io/). Omit for the default SaaS cluster.
# GALILEO_CONSOLE_URL=https://console.demo-v2.galileocloud.io/

# Galileo destination — project + log stream must exist (or will be auto-created on first write).
GALILEO_PROJECT=arcade-galileo-demo
GALILEO_LOG_STREAM=dev

# Arcade requires a user_id on every tool call for per-user tracking / OAuth scoping.
# For no-auth toolkits (math, web search) any stable identifier works.
USER_ID=you@example.com
