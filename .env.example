# Copy to .env and fill in real values.

OPENAI_API_KEY=sk-...
ARCADE_API_KEY=arc_...
GALILEO_API_KEY=...

# Galileo destination — project + log stream the GalileoSpanProcessor targets.
# galileo_context.init(...) creates these on first write if your tenant has auto-create.
GALILEO_PROJECT=arcade-galileo-demo
GALILEO_LOG_STREAM=default

# Optional — Galileo console URL for non-default clusters (dev / staging / demo-v2 / self-hosted).
# Default is the SaaS console at https://app.galileo.ai/. If you set this, GALILEO_API_KEY
# must be a key issued on that cluster. The GalileoSpanProcessor reads this to derive the
# correct OTLP endpoint — no manual GALILEO_OTLP_ENDPOINT needed.
# GALILEO_CONSOLE_URL=https://console.demo-v2.galileocloud.io/

# Arcade requires a user_id on every tool call for per-user tracking and OAuth scoping.
# Use your real Google email — Gmail / Google Docs tools cache OAuth tokens per
# ARCADE_USER_ID, so reusing the same value lets the demo skip the consent step
# on subsequent runs.
ARCADE_USER_ID=you@example.com
